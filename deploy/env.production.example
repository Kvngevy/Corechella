# Corechella — production VPS (copy to .env.production.local on server)

NODE_ENV=production
PORT=3002
HOSTNAME=127.0.0.1
LOG_LEVEL=warn
DB_READ_CACHE_MS=3000

# App
NEXT_PUBLIC_APP_URL=https://corechella.com
JWT_SECRET=change-me-long-random-string
QR_SECRET=change-me-long-random-string

# Database — prefer external MongoDB Atlas on 2GB VPS (saves ~300–500MB RAM)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/corechella
MONGODB_DB_NAME=corechella
MONGODB_MAX_POOL_SIZE=3

# Optional Redis (omit on small VPS — falls back to Mongo/file)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Wavy payments
NEXT_PUBLIC_WAVY_PUBLISHABLE_KEY=
WAVY_SECRET_KEY=
WAVY_WEBHOOK_SECRET=
WAVY_API_BASE=https://api.wavy.ng

# Admin seed (change after first login)
SUPER_ADMIN_EMAIL=admin@corechella.com
SUPER_ADMIN_PASSWORD=
